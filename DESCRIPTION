Package: HydraR
Type: Package
Title: Stateful Agentic Orchestration for R (CLI-First)
Version: 0.1.0
Authors@R: c(person(given = "Ignatius",
                    family = "Pang",
                    role = "aut"),
             person(given = "Aidan",
                    family = "Tay",
                    role = "aut"),
             person(given = c("APAF", "Agentic"),
                    family = "Workflow",
                    role = "cre",
